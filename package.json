{
  "name": "firstreply-landing",
  "version": "0.1.0",
  "private": true,
  "description": "Landing page for FirstReply — a micro-SaaS that helps small Lithuanian service and installation businesses respond to written inquiries faster.",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "tsx --test tests/*.test.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "libphonenumber-js": "^1.13.8",
    "next": "15.5.20",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.2.0",
    "@types/node": "20.17.12",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "autoprefixer": "10.4.20",
    "eslint": "9.18.0",
    "eslint-config-next": "15.5.20",
    "eslint-config-prettier": "9.1.0",
    "postcss": "8.4.49",
    "prettier": "3.4.2",
    "prettier-plugin-tailwindcss": "0.6.9",
    "prisma": "^6.19.3",
    "tailwindcss": "3.4.17",
    "tsx": "^4.22.5",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
