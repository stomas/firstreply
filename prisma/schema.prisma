generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENT
  SUPER_ADMIN
}

enum SourceIntegrationType {
  WEB_FORM
  PASLAUGOS_LT
}

enum SourceIntegrationTransport {
  HTTP_WEBHOOK
  RESEND_EMAIL
}

enum SourceIntegrationStatus {
  ACTIVE
  DISABLED
}

enum InboundEventStatus {
  PROCESSING
  COMPLETED
  FAILED
  REJECTED
}

enum ConversationStatus {
  NEEDS_REPLY
  WAITING_CUSTOMER
  MANUAL_REVIEW
  CLOSED
}

enum ConversationMessageDirection {
  INBOUND
  OUTBOUND
}

enum ConversationActivityType {
  ANSWERED_EXTERNALLY
  REOPENED
  CLOSED
}

model Client {
  id          String   @id @default(cuid())
  tenantId    String?  @unique @map("tenant_id") @db.Uuid
  companyName String   @map("company_name")
  ownerEmail  String   @map("owner_email")
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant               Tenant?               @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  services             Service[]
  pricingRules         PricingRule[]
  decisionRequirements DecisionRequirement[]
  availabilityRules    AvailabilityRule[]
  leads                Lead[]
  users                User[]                @relation("ClientUsers")
  selectedSessions     AuthSession[]         @relation("SelectedClientSessions")
  sourceIntegrations   SourceIntegration[]
  conversations        Conversation[]

  @@map("clients")
}

model Tenant {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  ownerEmail String   @map("owner_email")
  status     String   @default("active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  client            Client?
  services          Service[]
  leads             Lead[]
  locationZones     LocationZone[]
  scheduleRules     ScheduleRule[]
  autosendPolicies  AutosendPolicy[]
  responseTemplates ResponseTemplate[]

  @@map("tenants")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(CLIENT)
  clientId     String?  @map("client_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  client                 Client?                @relation("ClientUsers", fields: [clientId], references: [id], onDelete: Cascade)
  sessions               AuthSession[]
  conversationActivities ConversationActivity[]

  @@index([clientId])
  @@map("users")
}

model AuthSession {
  id               String   @id
  userId           String   @map("user_id")
  selectedClientId String?  @map("selected_client_id")
  expiresAt        DateTime @map("expires_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  selectedClient Client? @relation("SelectedClientSessions", fields: [selectedClientId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model Service {
  id                  String   @id @default(cuid())
  clientId            String   @map("client_id")
  tenantId            String?  @map("tenant_id") @db.Uuid
  name                String
  label               String?
  keywords            Json?
  rangePolicy         String   @default("manual_review") @map("range_policy")
  offeringDescription String?  @map("offering_description")
  offeringFollowup    String?  @map("offering_followup")
  active              Boolean  @default(true)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  client               Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tenant               Tenant?               @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  subjects             ServiceSubject[]
  pricingRules         PricingRule[]
  decisionRequirements DecisionRequirement[]
  availabilityRules    AvailabilityRule[]
  leads                Lead[]

  @@index([tenantId, active])
  @@index([clientId, active])
  @@map("services")
}

model ServiceSubject {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  serviceId     String   @map("service_id")
  subjectKey    String   @map("subject_key")
  labelLt       String   @map("label_lt")
  descriptionLt String   @map("description_lt")
  synonyms      Json
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, subjectKey])
  @@map("service_subjects")
}

model PricingRule {
  id              String    @id @default(cuid())
  clientId        String    @map("client_id")
  serviceId       String    @map("service_id")
  name            String
  priceMin        Decimal?  @map("price_min") @db.Decimal(10, 2)
  priceMax        Decimal?  @map("price_max") @db.Decimal(10, 2)
  unit            String?
  conditions      Json?
  exclusions      Json?
  disclaimerText  String?   @map("disclaimer_text")
  autoSendAllowed Boolean   @default(false) @map("auto_send_allowed")
  active          Boolean   @default(true)
  rule            Json?
  validFrom       DateTime  @default(now()) @map("valid_from")
  validTo         DateTime? @map("valid_to")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([clientId, serviceId, active])
  @@map("pricing_rules")
}

model DecisionRequirement {
  id                    String    @id @default(cuid())
  clientId              String    @map("client_id")
  serviceId             String    @map("service_id")
  requirementKey        String    @map("requirement_key")
  label                 String
  requiredFor           String    @map("required_for")
  questionTextIfMissing String    @map("question_text_if_missing")
  blocksAutoSend        Boolean   @default(true) @map("blocks_auto_send")
  priority              Int       @default(100)
  active                Boolean   @default(true)
  required              Boolean   @default(true)
  affectsPrice          Boolean   @default(false) @map("affects_price")
  expectedFact          Json?     @map("expected_fact")
  validation            Json?
  validFrom             DateTime  @default(now()) @map("valid_from")
  validTo               DateTime? @map("valid_to")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([clientId, serviceId, active, priority])
  @@map("decision_requirements")
}

model AvailabilityRule {
  id                String    @id @default(cuid())
  clientId          String    @map("client_id")
  serviceId         String    @map("service_id")
  location          String?
  status            String
  earliestStartText String?   @map("earliest_start_text")
  noteForCustomer   String?   @map("note_for_customer")
  validUntil        DateTime? @map("valid_until")
  autoSendAllowed   Boolean   @default(false) @map("auto_send_allowed")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([clientId, serviceId, location])
  @@map("availability_rules")
}

model Lead {
  id                 String    @id @default(cuid())
  clientId           String    @map("client_id")
  tenantId           String?   @map("tenant_id") @db.Uuid
  serviceId          String?   @map("service_id")
  sourceType         String    @map("source_type")
  source             String?
  isTest             Boolean   @default(false) @map("is_test")
  status             String
  customerName       String?   @map("customer_name")
  customerEmail      String?   @map("customer_email")
  customerPhone      String?   @map("customer_phone")
  city               String?
  originalMessage    String    @map("original_message")
  rawText            String?   @map("raw_text")
  formFields         Json?     @map("form_fields")
  parsedJson         Json?     @map("parsed_json")
  parseResult        Json?     @map("parse_result")
  decisionResult     Json?     @map("decision_result")
  responseDraft      String?   @map("response_draft")
  responseSentAt     DateTime? @map("response_sent_at")
  asksPrice          Boolean?  @map("asks_price")
  asksAvailability   Boolean?  @map("asks_availability")
  isUrgent           Boolean?  @map("is_urgent")
  hasAttachments     Boolean?  @map("has_attachments")
  manualReviewReason String?   @map("manual_review_reason")
  errorCode          String?   @map("error_code")
  shadowParseResult  Json?     @map("shadow_parse_result")
  shadowDiff         Json?     @map("shadow_diff")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  client        Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tenant        Tenant?        @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  service       Service?       @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  responses     LeadResponse[]
  conversation  Conversation?
  inboundEvents InboundEvent[]

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([clientId, createdAt])
  @@index([clientId, isTest, createdAt])
  @@index([clientId, status])
  @@map("leads")
}

model LeadResponse {
  id                 String   @id @default(cuid())
  leadId             String   @map("lead_id")
  responseType       String   @map("response_type")
  draftText          String?  @map("draft_text")
  sentText           String?  @map("sent_text")
  status             String
  autoSendAllowed    Boolean  @default(false) @map("auto_send_allowed")
  manualReviewReason String?  @map("manual_review_reason")
  decisionJson       Json?    @map("decision_json")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
  @@index([status])
  @@map("responses")
}

model SourceIntegration {
  id             String                     @id @default(cuid())
  clientId       String                     @map("client_id")
  sourceType     SourceIntegrationType      @map("source_type")
  transport      SourceIntegrationTransport
  name           String
  status         SourceIntegrationStatus    @default(ACTIVE)
  routingAddress String?                    @unique @map("routing_address")
  secretVersion  Int                        @default(1) @map("secret_version")
  createdAt      DateTime                   @default(now()) @map("created_at")
  updatedAt      DateTime                   @updatedAt @map("updated_at")

  client        Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  inboundEvents InboundEvent[]
  conversations Conversation[]
  messages      ConversationMessage[]

  @@index([clientId, status])
  @@index([clientId, sourceType])
  @@map("source_integrations")
}

model Conversation {
  id                  String             @id @default(cuid())
  clientId            String             @map("client_id")
  sourceIntegrationId String             @map("source_integration_id")
  leadId              String?            @unique @map("lead_id")
  status              ConversationStatus @default(NEEDS_REPLY)
  subject             String?
  customerName        String?            @map("customer_name")
  customerEmail       String?            @map("customer_email")
  lastInboundAt       DateTime?          @map("last_inbound_at")
  firstResponseAt     DateTime?          @map("first_response_at")
  closedAt            DateTime?          @map("closed_at")
  inboundVersion      Int                @default(0) @map("inbound_version")
  responseVersion     Int                @default(0) @map("response_version")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  client            Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sourceIntegration SourceIntegration      @relation(fields: [sourceIntegrationId], references: [id], onDelete: Cascade)
  lead              Lead?                  @relation(fields: [leadId], references: [id], onDelete: SetNull)
  messages          ConversationMessage[]
  activities        ConversationActivity[]

  @@index([clientId, status, updatedAt])
  @@index([sourceIntegrationId, updatedAt])
  @@map("conversations")
}

model ConversationMessage {
  id                  String                       @id @default(cuid())
  conversationId      String                       @map("conversation_id")
  sourceIntegrationId String                       @map("source_integration_id")
  provider            String
  providerMessageId   String                       @map("provider_message_id")
  internetMessageId   String?                      @map("internet_message_id")
  inReplyTo           String?                      @map("in_reply_to")
  references          Json?
  direction           ConversationMessageDirection @default(INBOUND)
  senderEmail         String?                      @map("sender_email")
  senderName          String?                      @map("sender_name")
  recipients          Json
  cc                  Json?
  subject             String?
  text                String
  attachments         Json?
  hasAttachments      Boolean                      @default(false) @map("has_attachments")
  manualReviewReason  String?                      @map("manual_review_reason")
  receivedAt          DateTime                     @map("received_at")
  createdAt           DateTime                     @default(now()) @map("created_at")

  conversation      Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sourceIntegration SourceIntegration @relation(fields: [sourceIntegrationId], references: [id], onDelete: Cascade)
  inboundEvent      InboundEvent?

  @@unique([sourceIntegrationId, providerMessageId])
  @@unique([sourceIntegrationId, internetMessageId])
  @@index([conversationId, receivedAt])
  @@map("conversation_messages")
}

model ConversationActivity {
  id             String                   @id @default(cuid())
  conversationId String                   @map("conversation_id")
  actorUserId    String?                  @map("actor_user_id")
  type           ConversationActivityType
  note           String?
  createdAt      DateTime                 @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  actorUser    User?        @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@map("conversation_activities")
}

model InboundEvent {
  id                  String             @id @default(cuid())
  sourceIntegrationId String             @map("source_integration_id")
  externalEventId     String             @map("external_event_id")
  provider            String
  status              InboundEventStatus @default(PROCESSING)
  attemptCount        Int                @default(1) @map("attempt_count")
  errorCode           String?            @map("error_code")
  errorMessage        String?            @map("error_message")
  metadata            Json?
  processingStartedAt DateTime           @default(now()) @map("processing_started_at")
  processingToken     String             @map("processing_token")
  completedAt         DateTime?          @map("completed_at")
  messageId           String?            @unique @map("message_id")
  leadId              String?            @map("lead_id")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  sourceIntegration SourceIntegration    @relation(fields: [sourceIntegrationId], references: [id], onDelete: Cascade)
  message           ConversationMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  lead              Lead?                @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@unique([sourceIntegrationId, externalEventId])
  @@index([status, updatedAt])
  @@index([sourceIntegrationId, createdAt])
  @@index([leadId])
  @@map("inbound_events")
}

model LocationZone {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  adminUnitCode String   @map("admin_unit_code")
  zone          String
  travelFeeEur  Decimal  @default(0) @map("travel_fee_eur") @db.Decimal(10, 2)
  served        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, adminUnitCode])
  @@map("location_zones")
}

model ScheduleRule {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  rule      Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("schedule_rules")
}

model AutosendPolicy {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  policy    Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("autosend_policies")
}

model ResponseTemplate {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  templateKey String   @map("template_key")
  body        String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, templateKey])
  @@map("response_templates")
}
