# -------------------------------------------------------------------
# FirstReply — environment variables
# Copy this file to `.env.local` for local development:
#   cp .env.example .env.local
# In Railway, set these in the service "Variables" tab.
# -------------------------------------------------------------------

# Public base URL of the site. Used for SEO metadata, OpenGraph,
# robots.txt and sitemap.xml. NO trailing slash.
# Local example: http://localhost:3000
# Production example: https://firstreply.lt
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OPTIONAL. Where demo lead submissions are forwarded (server-side POST).
# Can be a Make.com / Zapier / n8n / Slack incoming webhook, or your CRM.
# If left empty, leads are only logged in the server console and the form
# still returns success. This is a SERVER-ONLY secret — never prefixed
# with NEXT_PUBLIC_ and never exposed to the browser.
LEAD_WEBHOOK_URL=

# REQUIRED for `/dashboard`, `/dashboard/test`, and Prisma migrations.
# PostgreSQL connection string.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public

# REQUIRED only when response drafts should be generated.
# If either value is missing, test flow stores manual review with:
# "AI generation is not configured."
OPENAI_API_KEY=
OPENAI_MODEL=

# OPTIONAL. Enables the LLM-first parser for `/dashboard/test`.
# Default false keeps the deterministic parser. When true, extraction uses
# DB-backed ClientRules and invalid/missing fields go to clarification/manual
# review instead of a deterministic extraction rescue pass.
LLM_FIRST_PARSE=false

# Node environment. Railway sets this to "production" automatically.
# Leave as "development" locally.
NODE_ENV=development

# REQUIRED to create a Super Admin account at `/super-admin/signup`.
# Use at least 24 random characters and remove/rotate it after setup.
SUPER_ADMIN_SIGNUP_CODE=

# OPTIONAL. Measurement-only AI parse comparison. This never affects decisions
# and adds an extra AI call when enabled.
SHADOW_AI_PARSE=false

# REQUIRED for source-specific inbound integrations.
# Master secret used to derive a separate WEB_FORM signing secret for every
# integration and secret version. Use at least 32 random bytes. SERVER ONLY.
INBOUND_SIGNING_MASTER_SECRET=

# REQUIRED for PASLAUGOS_LT inbound and human-approved outbound email.
# Resend API key retrieves inbound email and provisions/sends from verified
# client domains.
# Webhook secret verifies the raw Resend/Svix inbound and delivery webhook body.
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

# REQUIRED for PASLAUGOS_LT routing address generation. This must be the
# inbound receiving domain configured and verified in Resend, without @.
# Example: in.firstreply.lt
RESEND_INBOUND_DOMAIN=

# Global emergency kill switch for real outbound email. Keep false after deploy
# until a client's sending domain is verified and a controlled smoke test is ready.
EMAIL_SENDING_ENABLED=false
