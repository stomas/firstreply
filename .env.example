# -------------------------------------------------------------------
# FirstReply — environment variables
# Copy this file to `.env.local` for local development:
#   cp .env.example .env.local
# In Railway, set these in the service "Variables" tab.
# -------------------------------------------------------------------

# Public base URL of the site. Used for SEO metadata, OpenGraph,
# robots.txt and sitemap.xml. NO trailing slash.
# Local example: http://localhost:3000
# Production example: https://firstreply.lt
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OPTIONAL. Where demo lead submissions are forwarded (server-side POST).
# Can be a Make.com / Zapier / n8n / Slack incoming webhook, or your CRM.
# If left empty, leads are only logged in the server console and the form
# still returns success. This is a SERVER-ONLY secret — never prefixed
# with NEXT_PUBLIC_ and never exposed to the browser.
LEAD_WEBHOOK_URL=

# REQUIRED for `/dashboard`, `/dashboard/test`, and Prisma migrations.
# PostgreSQL connection string.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public

# REQUIRED until full auth exists. Must match a real `clients.id` row.
FIRSTREPLY_DEFAULT_CLIENT_ID=

# REQUIRED only when response drafts should be generated.
# If either value is missing, test flow stores manual review with:
# "AI generation is not configured."
OPENAI_API_KEY=
OPENAI_MODEL=

# Node environment. Railway sets this to "production" automatically.
# Leave as "development" locally.
NODE_ENV=development
